rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is the authenticated owner (non-anonymous)
    function isOwner() {
      return request.auth != null && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // Projects are publicly readable, but only the owner can create, update, or delete.
    match /projects/{projectId} {
      allow read: if true;
      allow write: if isOwner();
    }
    
    // Analysis history is private to the owner. Only the owner can execute/store audits.
    match /analyses/{analysisId} {
      allow read, write: if isOwner();
    }

    // User profiles are publicly readable, but only the specific owner can modify their own.
    match /user_profiles/{ownerUid} {
      allow read: if true;
      allow write: if isOwner() && request.auth.uid == ownerUid;
      
      match /{allSubcollections=**} {
        allow read: if true;
        allow write: if isOwner() && request.auth.uid == ownerUid;
      }
    }
  }
}