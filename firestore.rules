rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read/write access to projects and analyses for the personal portfolio prototype
    match /projects/{projectId} {
      allow read, write: if true;
    }
    
    match /analyses/{analysisId} {
      allow read, write: if true;
    }

    // Single-owner portfolio structure rules
    match /user_profiles/{ownerUid} {
      allow read, write: if true;
      
      match /social_media_links/{id} { allow read, write: if true; }
      match /categories/{id} { allow read, write: if true; }
      match /skills/{id} { allow read, write: if true; }
      match /portfolio_items/{id} { allow read, write: if true; }
      
      // Recursive match for any other subcollections
      match /{allSubcollections=**} {
        allow read, write: if true;
      }
    }
  }
}